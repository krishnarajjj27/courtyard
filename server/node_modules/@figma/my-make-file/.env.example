# Frontend (Vite) environment variables
# Copy this file to .env.local and fill real values.

VITE_SUPABASE_URL=https://yourdomain.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# OAuth redirect URLs for Google Sign-In
VITE_SITE_URL=https://yourdomain.com
VITE_OAUTH_REDIRECT_BASE_URL=https://yourdomain.com

# Optional: override email verification behavior in non-production environments
# true|false
VITE_REQUIRE_EMAIL_VERIFICATION=false

# API Base URL
VITE_API_BASE_URL=https://your-api-domain.com
